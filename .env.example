# SmartPaper Environment Variables
# Copy this to .env and fill in your keys

# Application Environment (dev, prod)
APP_ENV=dev

# DeepSeek Configuration
SP_LLM__OPENAI_DEEPSEEK__API_KEY=sk-your-deepseek-key-here
SP_LLM__OPENAI_DEEPSEEK__BASE_URL=https://api.deepseek.com/v1

# ZhipuAI Configuration
SP_LLM__ZHIPUAI__API_KEY=your-zhipu-key-here

# SiliconFlow Configuration
SP_LLM__OPENAI_SILICONFLOW__API_KEY=your-siliconflow-key-here

# Document Converter
SP_DOCUMENT_CONVERTER__CONVERTER_NAME=markitdown
