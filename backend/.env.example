# FastAPI 后端环境配置

# 应用配置
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8713

# CORS 配置
ALLOWED_ORIGINS=["http://localhost:3071","http://localhost:8080"]

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./smartpaper.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/smartpaper

# JWT 认证配置
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# LLM 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=glm-4

# Zotero 配置
ZOTERO_API_KEY=your_zotero_api_key_here
ZOTERO_USER_ID=your_zotero_user_id_here

# 日志配置
LOG_LEVEL=INFO

# 文件存储
MAX_UPLOAD_SIZE=104857600
